# Local development (optional — default uses Vite proxy /api → localhost:5001)
# VITE_CBT_API_URL=http://localhost:5001/api

# Production (set in Vercel → Settings → Environment Variables)
# VITE_CBT_API_URL=https://cbt-api.live.rydlearning.com/api

# Parent app URL for assigned-practice users (pause / results redirect)
# VITE_RYD_PARENT_APP_URL=http://localhost:3001
# VITE_RYD_PARENT_APP_URL=https://parent.rydlearning.com

# RYD Learning API (practice subscription billing)
# VITE_RYD_API_URL=http://localhost:3000
# VITE_RYD_API_URL=https://api-pro.rydlearning.com
